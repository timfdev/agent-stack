# Copy to .env (gitignored) and fill in. Real secrets live in secrets/, not here.

# --- Image pins (bump deliberately) ---
AGENT_ZERO_IMAGE=agent0ai/agent-zero:ready
MCP_GATEWAY_IMAGE=docker/mcp-gateway:v0.42.1
LINKEDIN_MCP_IMAGE=stickerdaniel/linkedin-mcp-server:4.12.0

# --- Networking ---
# Agent Zero web UI binds to this host interface on the Mac mini.
# Recommended: the Mac mini's Meshnet IP (100.x.x.x) — Meshnet already
# provides private addressing, WireGuard transport, and per-peer ACLs,
# so any linked Meshnet device hits the UI directly with no SSH hop.
# Set a UI password on first run.
# Fallback to 127.0.0.1 only if you want to layer SSH key auth on top.
AGENT_ZERO_BIND=100.x.x.x
AGENT_ZERO_PORT=50001

# --- Runtime ---
TZ=Europe/Amsterdam

# --- Discord plugin (read by a0-discord) ---
# Channel IDs the plugin should listen / write to. Fill in after creating channels.
DISCORD_CHANNEL_GENERAL=
DISCORD_CHANNEL_LEADS=
DISCORD_CHANNEL_AUDIT=
