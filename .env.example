# Copy to .env (gitignored, chmod 600) and fill in.
# This file holds both config AND runtime credentials — compose interpolates
# them into the container environment. Neither Agent Zero nor a0-discord
# support the Docker `_FILE` convention, so this is the simplest path.

# --- Image pins (bump deliberately) ---
AGENT_ZERO_IMAGE=agent0ai/agent-zero:ready
MCP_GATEWAY_IMAGE=docker/mcp-gateway:v0.42.1
LINKEDIN_MCP_IMAGE=stickerdaniel/linkedin-mcp-server:4.12.0

# --- Networking ---
# Host interface the Agent Zero UI (port 50001) binds to.
# Mac mini: the Meshnet IP (100.x.x.x) — any linked Meshnet device reaches
# the UI directly; Meshnet's per-peer ACLs gate access. Set a UI password
# on first run.
# Laptop test: 127.0.0.1.
AGENT_ZERO_BIND=100.x.x.x

# --- Credentials ---
# Agent Zero LLM provider. Set a low monthly $ cap on the key.
OPENAI_API_KEY=

# Discord bot token for the agent's bot account. Consumed by the a0-discord
# plugin via plain env (no _FILE indirection supported).
DISCORD_BOT_TOKEN=

# Fine-grained Personal Access Token for the bot's GitHub account
# (timfdev). Lets the agent clone, commit, push, and (if scoped)
# create repos from inside its container. Generate at:
#   https://github.com/settings/personal-access-tokens
# Suggested minimal scopes:
#   - Repository access: All repositories under timfdev
#   - Contents: Read and write           (clone/push)
#   - Administration: Read and write     (create/delete repos)
#   - Issues, Pull requests: Read/write  (file PRs/issues)
# Expiry: 90 days; rotate by replacing this value and restarting the stack.
GITHUB_TOKEN=

# --- Agent Zero settings seed ---
# These are read on FIRST boot (when /a0/usr/settings.json doesn't yet
# exist) and become the initial value of the corresponding field. Once
# settings.json is written, the file is authoritative and these env
# vars are ignored — the Web UI can edit them from then on. To re-seed
# from scratch, delete data/agent-zero/usr/settings.json and restart.

# Auto-connect to the local mcp-gateway container as a single MCP
# server on first boot. The JSON value matches Agent Zero's
# settings.mcp_servers schema (mcpServers envelope; type
# "streamable-http" = HTTP transport that matches our gateway
# `--transport streaming --port 8811`).
A0_SET_mcp_servers={"mcpServers":{"gateway":{"type":"streamable-http","url":"http://mcp-gateway:8811","disabled":false}}}

# Model pins. Note: there are two related but DIFFERENT envvar
# mechanisms in Agent Zero — top-level Settings (this section, flat
# `A0_SET_<setting>`) and plugin sub-configs (nested
# `A0_SET_<plugin>__<path>__<key>`). The model config may be either
# depending on Agent Zero version. If these don't take effect, check
# data/agent-zero/usr/settings.json after first boot to see the actual
# field names and adjust.
A0_SET__model_config__chat_model__provider=openai
A0_SET__model_config__chat_model__name=gpt-4o-mini
A0_SET__model_config__utility_model__provider=openai
A0_SET__model_config__utility_model__name=gpt-4o-mini
# Embedding model stays on the shipped default (local HuggingFace
# model, no API cost).

# --- Discord channel routing ---
# Channel IDs the plugin listens / writes to. Fill in after creating channels.
DISCORD_CHANNEL_GENERAL=
DISCORD_CHANNEL_LEADS=
DISCORD_CHANNEL_AUDIT=
DISCORD_CHANNEL_DM=

# Discord server id
DISCORD_GUILD_ID=